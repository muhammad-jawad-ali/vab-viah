# RishtaAI Frontend env — copy to `.env` for local dev.
# All vars prefixed `EXPO_PUBLIC_` are inlined into the JS bundle at build time
# and visible client-side. Never put secrets here.

# Backend API base URL. No trailing slash.
#
# Pick the one that matches how you're running the app:
#
#  iOS simulator / Android emulator on this laptop:
#    http://localhost:3000        (iOS sim) — works because sim shares host loopback
#    http://10.0.2.2:3000         (Android emulator) — emulator's alias for host
#
#  Physical phone on the SAME Wi-Fi as the laptop (primary dev loop):
#    http://<laptop-LAN-ip>:3000  e.g. http://192.168.1.42:3000
#    Find your IP:  Windows -> `ipconfig` IPv4; macOS/Linux -> `ifconfig | grep inet`
#    Make sure the backend is running with HOST=0.0.0.0 (server.ts already does).
#    Open inbound port 3000 in Windows Defender Firewall if blocked.
#
#  Physical phone on a different network / tunneled (fallback):
#    Run `npx expo start --tunnel` AND point at the Railway URL below.
#
#  Railway production (judge demo / off-network testing):
#    https://<your-service>.up.railway.app
EXPO_PUBLIC_API_URL=http://localhost:3000
