# RishtaAI Frontend env — copy to `.env` for local dev.
# All vars prefixed `EXPO_PUBLIC_` are inlined into the JS bundle at build time
# and visible client-side. Never put secrets here.

# Backend API base URL. No trailing slash.
#
# Local dev (Expo Go on simulator):       http://localhost:3000
# Local dev (Expo Go on physical phone):  http://<your-laptop-LAN-ip>:3000
#                                         (e.g. http://192.168.1.42:3000)
# Local dev with `expo start --tunnel`:   keep localhost:3000; tunnel proxies for you
# Railway production:                     https://<your-railway-service>.up.railway.app
EXPO_PUBLIC_API_URL=http://localhost:3000
